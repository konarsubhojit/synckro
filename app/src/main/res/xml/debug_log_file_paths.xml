<?xml version="1.0" encoding="utf-8"?>
<!--
  FileProvider path descriptor used by the log-export feature.
  FileLoggingTree writes to filesDir/logs/ (internal storage). The log-export
  bundle zip is written to cacheDir/log_export/. Both are served as
  content:// URIs so callers need no storage permission.
-->
<paths>
    <files-path name="debug_logs" path="logs/" />
    <cache-path name="log_export" path="log_export/" />
</paths>
