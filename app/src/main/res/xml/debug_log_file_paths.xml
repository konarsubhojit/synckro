<?xml version="1.0" encoding="utf-8"?>
<!--
  FileProvider path descriptor used by the debug-only log-export feature.
  FileLoggingTree writes to filesDir/logs/ (internal storage), which the
  FileProvider serves here as a content:// URI for the share-intent fallback
  on API 26-28. On API 29+ the export button copies directly to MediaStore
  Downloads so the user can browse the file without a USB cable.
-->
<paths>
    <files-path name="debug_logs" path="logs/" />
</paths>
